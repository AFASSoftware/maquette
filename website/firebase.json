{
  "hosting": {
    "public": "./build/website",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "https://maquette.js.org/",
        "type": 301
      },
      {
        "source": "/:path*",
        "destination": "https://maquette.js.org/:path",
        "type": 301
      }
    ]
  }
}
